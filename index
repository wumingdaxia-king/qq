<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>模拟登录页</title>
  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: #f5f7fb;
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
    }

    .login-box {
      width: 360px;
      background: #fff;
      padding: 28px;
      border-radius: 12px;
      box-shadow: 0 8px 24px rgba(0,0,0,0.1);
    }

    .login-box h2 {
      text-align: center;
      margin-bottom: 24px;
    }

    .form-item {
      margin-bottom: 16px;
    }

    .form-item input {
      width: 100%;
      box-sizing: border-box;
      padding: 10px 12px;
      border: 1px solid #ccc;
      border-radius: 8px;
      outline: none;
    }

    .captcha-row {
      display: flex;
      gap: 10px;
      align-items: center;
    }

    .captcha-row input {
      flex: 1;
    }

    .captcha-box {
      width: 110px;
      height: 42px;
      line-height: 42px;
      text-align: center;
      border-radius: 8px;
      background: linear-gradient(135deg, #dfe9f3, #ffffff);
      border: 1px solid #ccc;
      user-select: none;
      cursor: pointer;
      font-size: 22px;
      font-weight: bold;
      letter-spacing: 4px;
      color: #333;
    }

    button {
      width: 100%;
      padding: 12px;
      border: none;
      border-radius: 8px;
      background: #1677ff;
      color: #fff;
      font-size: 16px;
      cursor: pointer;
    }

    button:hover {
      background: #0958d9;
    }

    .tip {
      margin-top: 12px;
      text-align: center;
      font-size: 14px;
      color: #666;
    }
  </style>
</head>
<body>
  <div class="login-box">
    <h2>登录系统</h2>

    <div class="form-item">
      <input type="text" id="username" placeholder="请输入用户名" />
    </div>

    <div class="form-item">
      <input type="password" id="password" placeholder="请输入密码" />
    </div>

    <div class="form-item captcha-row">
      <input type="text" id="captchaInput" placeholder="请输入验证码" />
      <div id="captchaBox" class="captcha-box" title="点击刷新验证码"></div>
    </div>

    <button id="loginBtn">登录</button>
    <div class="tip">测试账号：admin　密码：123456</div>
  </div>

  <script>
    let currentCaptcha = "";

    function generateCaptcha(length = 4) {
      const chars = "ABCDEFGHJKLMNPQRSTUVWXYZabcdefghjkmnpqrstuvwxyz23456789";
      let code = "";
      for (let i = 0; i < length; i++) {
        const index = Math.floor(Math.random() * chars.length);
        code += chars[index];
      }
      return code;
    }

    function renderCaptcha() {
      currentCaptcha = generateCaptcha(4);
      document.getElementById("captchaBox").textContent = currentCaptcha;
    }

    function login() {
      const username = document.getElementById("username").value.trim();
      const password = document.getElementById("password").value.trim();
      const captchaInput = document.getElementById("captchaInput").value.trim();

      if (!username || !password || !captchaInput) {
        alert("请填写完整信息");
        return;
      }

      if (captchaInput.toLowerCase() !== currentCaptcha.toLowerCase()) {
        alert("验证码错误");
        renderCaptcha();
        document.getElementById("captchaInput").value = "";
        return;
      }

      if (username === "admin" && password === "123456") {
        alert("登录成功");
      } else {
        alert("用户名或密码错误");
      }

      renderCaptcha();
      document.getElementById("captchaInput").value = "";
    }

    document.getElementById("captchaBox").addEventListener("click", renderCaptcha);
    document.getElementById("loginBtn").addEventListener("click", login);

    renderCaptcha();
  </script>
</body>
</html>
