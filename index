<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>QQ邮箱 - 安全登录</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
            background: linear-gradient(135deg, #0b4f8a 0%, #1a7bc9 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            margin: 0;
            padding: 20px;
        }
        
        .login-container {
            width: 100%;
            max-width: 400px;
        }
        
        .login-box {
            background: white;
            border-radius: 12px;
            padding: 40px 30px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
        }
        
        .url-bar {
            background: #f8f9fa;
            padding: 12px 15px;
            border-radius: 8px;
            margin-bottom: 25px;
            font-size: 13px;
            border: 1px solid #e9ecef;
            display: flex;
            align-items: center;
            gap: 8px;
            flex-wrap: wrap;
        }
        
        .url-lock {
            color: #28a745;
            font-size: 14px;
        }
        
        .url-text {
            color: #1a73e8;
            font-family: monospace;
            font-weight: 500;
            word-break: break-all;
            flex: 1;
        }
        
        .url-warning {
            color: #dc3545;
            font-size: 12px;
            font-weight: 500;
        }
        
        .logo {
            text-align: center;
            margin-bottom: 30px;
        }
        
        .qq-icon {
            width: 80px;
            height: 80px;
            margin: 0 auto 15px;
            background: #1a73e8;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 40px;
            color: white;
            box-shadow: 0 5px 15px rgba(26, 115, 232, 0.3);
        }
        
        .logo h2 {
            color: #202124;
            font-size: 24px;
            margin-bottom: 5px;
        }
        
        .logo p {
            color: #5f6368;
            font-size: 14px;
        }
        
        .warning-note {
            background: #fff3cd;
            border: 1px solid #ffeeba;
            border-radius: 8px;
            padding: 12px 15px;
            margin-bottom: 20px;
            color: #856404;
            font-size: 13px;
            text-align: center;
        }
        
        .input-group {
            margin-bottom: 20px;
        }
        
        .input-group label {
            display: block;
            margin-bottom: 8px;
            color: #202124;
            font-size: 14px;
            font-weight: 500;
        }
        
        .input-field {
            width: 100%;
            padding: 14px 16px;
            border: 1px solid #dadce0;
            border-radius: 8px;
            font-size: 14px;
            transition: all 0.3s;
        }
        
        .input-field:focus {
            outline: none;
            border-color: #1a73e8;
            box-shadow: 0 0 0 2px rgba(26, 115, 232, 0.2);
        }
        
        .options {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin: 15px 0 25px;
        }
        
        .remember {
            display: flex;
            align-items: center;
            gap: 8px;
            color: #5f6368;
            font-size: 14px;
        }
        
        .forgot-link {
            color: #1a73e8;
            text-decoration: none;
            font-size: 14px;
        }
        
        .forgot-link:hover {
            text-decoration: underline;
        }
        
        .login-btn {
            width: 100%;
            padding: 14px;
            background: #1a73e8;
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 16px;
            font-weight: 500;
            cursor: pointer;
            transition: background 0.3s;
            margin-bottom: 20px;
        }
        
        .login-btn:hover {
            background: #1557b0;
        }
        
        .qr-section {
            text-align: center;
            padding-top: 20px;
            border-top: 1px solid #e0e0e0;
        }
        
        .qr-placeholder {
            width: 120px;
            height: 120px;
            background: #f5f5f5;
            margin: 0 auto 10px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #5f6368;
            font-size: 12px;
            border: 1px dashed #dadce0;
        }
        
        .qr-text {
            color: #5f6368;
            font-size: 13px;
        }
        
        .footer-links {
            margin-top: 20px;
            text-align: center;
            font-size: 12px;
        }
        
        .footer-links a {
            color: #5f6368;
            text-decoration: none;
            margin: 0 10px;
        }
        
        .footer-links a:hover {
            color: #1a73e8;
        }
        
        .message {
            margin-top: 15px;
            padding: 12px;
            border-radius: 8px;
            font-size: 13px;
            display: none;
        }
        
        .message.error {
            background: #fce8e8;
            color: #c5221f;
            display: block;
        }
        
        .message.success {
            background: #e6f4ea;
            color: #137333;
            display: block;
        }
        
        .save-info {
            background: #e8f4fd;
            border-radius: 8px;
            padding: 10px;
            margin-top: 15px;
            font-size: 12px;
            color: #0056b3;
            text-align: center;
        }
        
        .data-panel {
            margin-top: 20px;
            background: white;
            border-radius: 8px;
            padding: 15px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.1);
        }
        
        .data-panel h4 {
            margin: 0 0 10px 0;
            color: #202124;
            font-size: 14px;
        }
        
        .data-content {
            background: #f5f5f5;
            padding: 10px;
            border-radius: 4px;
            font-size: 12px;
            max-height: 200px;
            overflow: auto;
        }
        
        .data-item {
            border-bottom: 1px solid #e0e0e0;
            padding: 8px 0;
        }
        
        .data-item:last-child {
            border-bottom: none;
        }
        
        .clear-btn {
            margin-top: 10px;
            padding: 8px 16px;
            background: #dc3545;
            color: white;
            border: none;
            border-radius: 4px;
            font-size: 12px;
            cursor: pointer;
            transition: background 0.3s;
        }
        
        .clear-btn:hover {
            background: #c82333;
        }
        
        .test-account {
            background: #e8f4fd;
            padding: 10px;
            border-radius: 8px;
            margin-top: 15px;
            font-size: 12px;
            color: #0056b3;
            text-align: center;
        }
    </style>
</head>
<body>
    <div class="login-container">
        <div class="login-box">
            <div class="url-bar">
                <span class="url-lock">🔒</span>
                <span class="url-text">https://mail.qq.com.secure-verify.com/login</span>
                <span class="url-warning">⚠️ 验证域名</span>
            </div>
            
            <div class="warning-note" id="warningNote">
                ⚠️ 教学演示 - 请不要输入真实密码！
            </div>
            
            <div class="logo">
                <div class="qq-icon">🐧</div>
                <h2>QQ邮箱</h2>
                <p>安全登录</p>
            </div>
            
            <div class="input-group">
                <label>QQ号码 / 邮箱账号</label>
                <input type="text" class="input-field" id="username" placeholder="请输入QQ号码或邮箱" value="test_user">
            </div>
            
            <div class="input-group">
                <label>密码</label>
                <input type="password" class="input-field" id="password" placeholder="请输入密码" value="test123">
            </div>
            
            <div class="options">
                <label class="remember">
                    <input type="checkbox" id="remember" checked> 记住登录状态
                </label>
                <a href="#" class="forgot-link" onclick="return false;">忘记密码？</a>
            </div>
            
            <button class="login-btn" onclick="handleLogin()">登 录</button>
            
            <div class="qr-section">
                <div class="qr-placeholder">
                    📱 扫码登录
                </div>
                <div class="qr-text">使用手机QQ扫码登录</div>
            </div>
            
            <div class="footer-links">
                <a href="#" onclick="return false;">帮助中心</a>
                <a href="#" onclick="return false;">隐私政策</a>
                <a href="#" onclick="return false;">意见反馈</a>
            </div>
            
            <div class="message" id="message"></div>
            
            <div class="test-account">
                📝 测试账号: test_user / test123
            </div>
        </div>
        
        <div class="data-panel">
            <h4>📊 捕获的数据记录</h4>
            <div class="data-content" id="dataContent">暂无数据</div>
            <button class="clear-btn" onclick="clearData()">清空记录</button>
            <div class="save-info" id="saveInfo">
                💾 数据将保存到浏览器本地
            </div>
        </div>
    </div>

    <script>
        // 存储捕获的数据
        let capturedData = JSON.parse(localStorage.getItem('phishing_demo_data')) || [];
        
        // 更新数据显示
        function updateDataPanel() {
            const dataContent = document.getElementById('dataContent');
            if (capturedData.length > 0) {
                let html = '';
                capturedData.slice(-5).reverse().forEach((item, index) => {
                    html += `
                        <div class="data-item">
                            <div><strong>${capturedData.length - index}.</strong> ${item.timestamp}</div>
                            <div>账号: ${item.username}</div>
                            <div>密码: ${'•'.repeat(item.password.length)}</div>
                        </div>
                    `;
                });
                html += `<div style="margin-top: 10px; color: #5f6368;">总计: ${capturedData.length} 条记录</div>`;
                dataContent.innerHTML = html;
            } else {
                dataContent.innerHTML = '暂无数据';
            }
            
            // 保存到localStorage
            localStorage.setItem('phishing_demo_data', JSON.stringify(capturedData));
        }
        
        // 处理登录
        function handleLogin() {
            const username = document.getElementById('username').value;
            const password = document.getElementById('password').value;
            const message = document.getElementById('message');
            const warningNote = document.getElementById('warningNote');
            const saveInfo = document.getElementById('saveInfo');
            
            if (username && password) {
                // 显示警告
                warningNote.style.display = 'block';
                
                // 准备数据
                const timestamp = new Date().toLocaleString('zh-CN');
                const data = {
                    username: username,
                    password: password,
                    timestamp: timestamp,
                    userAgent: navigator.userAgent.substring(0, 50) + '...'
                };
                
                // 添加到数组
                capturedData.push(data);
                
                // 更新显示
                updateDataPanel();
                
                // 显示消息
                message.className = 'message error';
                message.innerHTML = `
                    ⚠️ 钓鱼演示 - 数据已捕获<br>
                    账号: ${username}<br>
                    密码长度: ${password.length} 字符<br>
                    时间: ${timestamp}<br>
                    <span style="color: #137333; margin-top: 10px; display: block;">
                    ✅ 数据已保存到浏览器
                    </span>
                `;
                
                // 更新保存信息
                saveInfo.innerHTML = `💾 最后保存: ${timestamp}`;
                
                // 清空密码
                document.getElementById('password').value = '';
                
                // 可选：下载数据到文件
                downloadData(data);
                
            } else {
                message.className = 'message error';
                message.innerHTML = '请输入账号和密码';
            }
        }
        
        // 下载数据到文件
        function downloadData(data) {
            // 创建下载链接
            const content = `时间: ${data.timestamp}\n账号: ${data.username}\n密码: ${data.password}\n用户代理: ${data.userAgent}\n${'='.repeat(50)}\n`;
            
            // 合并所有数据
            let allContent = 'QQ邮箱钓鱼演示 - 捕获数据记录\n';
            allContent += '='.repeat(50) + '\n\n';
            capturedData.forEach((item, index) => {
                allContent += `记录 ${index + 1}:\n`;
                allContent += `时间: ${item.timestamp}\n`;
                allContent += `账号: ${item.username}\n`;
                allContent += `密码: ${item.password}\n`;
                allContent += '-'.repeat(30) + '\n';
            });
            
            const blob = new Blob([allContent], { type: 'text/plain;charset=utf-8' });
            const link = document.createElement('a');
            link.href = URL.createObjectURL(blob);
            link.download = `qq_phishing_data_${new Date().toISOString().slice(0,10)}.txt`;
            link.click();
        }
        
        // 清空数据
        function clearData() {
            if (confirm('确定要清空所有记录吗？')) {
                capturedData = [];
                localStorage.removeItem('phishing_demo_data');
                updateDataPanel();
                document.getElementById('message').style.display = 'none';
                document.getElementById('saveInfo').innerHTML = '💾 数据已清空';
            }
        }
        
        // 初始化显示
        updateDataPanel();
        
        // 自动显示警告
        setTimeout(() => {
            document.getElementById('warningNote').style.display = 'block';
        }, 1000);
    </script>
</body>
</html>
